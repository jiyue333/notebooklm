APP_NAME=NotebookLM Backend
APP_ENV=development
DEBUG=true
API_PREFIX=/api
HOST=127.0.0.1
PORT=8080
SECRET_KEY=change-me
AUTH_TOKEN_TTL_DAYS=30

DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/notebooklm
DATABASE_ECHO=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

REDIS_URL=redis://127.0.0.1:6379/0
REDIS_DECODE_RESPONSES=false

EXA_BASE_URL=https://api.exa.ai
SEARCH_INLINE_DEADLINE_MS=4500

EMBEDDING_PROVIDER=OpenAI
EMBEDDING_API_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSION=3072
CHUNK_TARGET_TOKENS=600
CHUNK_OVERLAP_TOKENS=80
SUMMARY_CACHE_TTL_DAYS=30

ROCKETMQ_NAMESRV_ADDR=127.0.0.1:9876
ROCKETMQ_TOPIC=notebook_async

OBJECT_STORAGE_ENDPOINT=127.0.0.1:9000
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
OBJECT_STORAGE_BUCKET=notebooklm
OBJECT_STORAGE_SECURE=false
OBJECT_STORAGE_REGION=

LOG_LEVEL=INFO
LOG_JSON=false

OTEL_ENABLED=true
OTEL_SERVICE_NAME=notebooklm-backend
OTEL_EXPORTER_OTLP_ENDPOINT=

LANGSMITH_ENABLED=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=notebooklm-backend
LANGSMITH_TRACING=false

CORS_ORIGINS=["http://127.0.0.1:5173","http://localhost:5173"]
