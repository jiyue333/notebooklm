# HELP notebooklm_benchmark_metric Offline benchmark metric exported from NotebookLM eval runners.
# TYPE notebooklm_benchmark_metric gauge
notebooklm_benchmark_metric{benchmark="search",metric_group="metrics",metric_name="authority_hit_rate"} 0.8333
notebooklm_benchmark_metric{benchmark="search",metric_group="metrics",metric_name="freshness_satisfaction_rate"} 0.8333
notebooklm_benchmark_metric{benchmark="search",metric_group="metrics",metric_name="mrr"} 0.8333
notebooklm_benchmark_metric{benchmark="search",metric_group="metrics",metric_name="ndcg_at_k"} 0.9205
notebooklm_benchmark_metric{benchmark="search",metric_group="metrics",metric_name="precision_at_k"} 0.4
notebooklm_benchmark_metric{benchmark="search",metric_group="metrics",metric_name="recall_at_k"} 1
# HELP notebooklm_benchmark_cases Number of cases covered by the benchmark report.
# TYPE notebooklm_benchmark_cases gauge
notebooklm_benchmark_cases{benchmark="search"} 6
