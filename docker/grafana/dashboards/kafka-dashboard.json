    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "应用侧最近 1 小时发往 Kafka 的消息数量。",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 5,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (tag, status) (increase(notebooklm_mq_publish_total[1h]))",
          "legendFormat": "{{tag}} / {{status}}",
          "refId": "A"
        }
      ],
      "title": "Published Messages (Last 1h)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
