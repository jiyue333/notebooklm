      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 6,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (tag, status) (increase(notebooklm_mq_consume_total[1h]))",
          "legendFormat": "{{tag}} / {{status}}",
          "refId": "A"
        }
      ],
      "title": "Consumed Messages (Last 1h)",
