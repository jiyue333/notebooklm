      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, input_type) (rate(notebooklm_ingest_ready_duration_ms_bucket[5m])))",
          "legendFormat": "{{input_type}}",
          "refId": "A"
        }
      ],
      "title": "Content Ready Latency P95",
      "type": "timeseries"
    }
