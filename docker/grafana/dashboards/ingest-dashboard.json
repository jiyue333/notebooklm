        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "id": 4,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
