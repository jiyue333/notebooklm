meta {
  name: Start Fast Search (Real Exa Required)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/notebooks/{{notebookMixedId}}/sources/search
  body: none
  auth: bearer
}

headers {
  content-type: application/json
}

auth:bearer {
  token: {{authToken}}
}

body {
  {
    "query": "research memory architecture",
    "mode": "fast",
    "maxResults": 5,
    "freshnessHours": 24
  }
}
