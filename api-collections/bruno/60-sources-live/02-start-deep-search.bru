meta {
  name: Start Deep Search (Real Exa Required)
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/notebooks/{{notebookMixedId}}/sources/search
  body: none
  auth: bearer
}

headers {
  content-type: application/json
}

auth:bearer {
  token: {{authToken}}
}

body {
  {
    "query": "longform research workflow",
    "mode": "deep",
    "maxResults": 10,
    "freshnessHours": 72
  }
}
