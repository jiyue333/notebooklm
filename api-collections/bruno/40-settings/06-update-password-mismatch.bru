meta {
  name: Update Password Mismatch
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/account/password
  body: none
  auth: bearer
}

headers {
  content-type: application/json
}

auth:bearer {
  token: {{authToken}}
}

body {
  {
    "oldPassword": "{{demoPassword}}",
    "newPassword": "new-demo-secret",
    "confirmPassword": "different-secret"
  }
}
