meta {
  name: Login No Key User
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/auth/login
  body: none
}

headers {
  content-type: application/json
}

body {
  {
    "username": "{{noKeyUsername}}",
    "password": "{{noKeyPassword}}"
  }
}

script:post-response {
  bru.setEnvVar("noKeyAuthToken", res.body.token)
}
