# =============== App ===============
# 应用名称，主要用于文档、日志和 OpenTelemetry service name 的默认语义。
APP_NAME="NotebookLM Backend"
# 运行环境。开发模式通常使用 development。
APP_ENV="development"
# 是否开启调试模式。开发环境通常为 true，生产环境建议 false。
DEBUG=true
# API 路由统一前缀。
API_PREFIX="/api"
# API 监听地址。
HOST="127.0.0.1"
# API 监听端口。
PORT=8080
# 鉴权签名密钥，本地开发可先用占位值，生产环境必须替换。
SECRET_KEY="change-me"
# 登录态 token 有效天数。
AUTH_TOKEN_TTL_DAYS=30
# 在线造数脚本默认访问的 API 基地址。
NOTEBOOKLM_BASE_URL="http://127.0.0.1:8080/api"
# 在线造数脚本使用的 Bearer Token，本地留空即可，使用前再填。
NOTEBOOKLM_API_TOKEN=""

# =============== Database ===============
# PostgreSQL 连接串，当前项目使用 asyncpg。
DATABASE_URL="postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/notebooklm"
# 是否输出 SQL 调试日志。
DATABASE_ECHO=false
# 连接池基础大小。
DATABASE_POOL_SIZE=10
# 连接池溢出上限。
DATABASE_MAX_OVERFLOW=20

# =============== Redis / Cache ===============
# Redis 连接串。
REDIS_URL="redis://127.0.0.1:6379/0"
# 是否把 Redis 返回值自动解码成字符串。
REDIS_DECODE_RESPONSES=false
# 是否启用 Redis 读缓存。
REDIS_CACHE_ENABLED=true
# notebook detail 稳定态缓存 TTL，单位秒。
CACHE_TTL_NOTEBOOK_DETAIL_SECONDS=30
# notebook detail 有待处理文章时的短 TTL，单位秒。
CACHE_TTL_NOTEBOOK_DETAIL_PENDING_SECONDS=2
# search session 已完成时缓存 TTL，单位秒。
CACHE_TTL_SEARCH_SESSION_COMPLETED_SECONDS=300
# search session 处理中时缓存 TTL，单位秒。
CACHE_TTL_SEARCH_SESSION_PENDING_SECONDS=2
# settings 视图缓存 TTL，单位秒。
CACHE_TTL_SETTINGS_SECONDS=900
# 是否启用 Redis bigkey/hotkey 巡检。
REDIS_INSPECTION_ENABLED=true
# Redis 巡检最短间隔，单位秒。
REDIS_INSPECTION_INTERVAL_SECONDS=900
# Redis 巡检最多扫描多少个 key。
REDIS_INSPECTION_SAMPLE_LIMIT=200
# Redis SCAN 每批拉取数量。
REDIS_INSPECTION_SCAN_COUNT=50
# bigkey 判定阈值，单位字节。
REDIS_BIGKEY_THRESHOLD_BYTES=262144
# hotkey 判定频次阈值。
REDIS_HOTKEY_FREQUENCY_THRESHOLD=32
# 巡检报告保留 TopN。
REDIS_INSPECTION_TOP_N=10

# =============== Search / Sampling ===============
# Exa API 基地址。
EXA_BASE_URL="https://api.exa.ai"
# 系统默认 Exa API Key。若用户在设置中配置个人 key，会优先使用用户 key。
EXA_DEFAULT_API_KEY=""
# inline search 最长等待时间，超过后转为异步，单位毫秒。
SEARCH_INLINE_DEADLINE_MS=4500
# 是否启用线上搜索采样评审。
SEARCH_REVIEW_SAMPLING_ENABLED=true
# 采样比例，建议在 0.01 到 0.05 之间。
SEARCH_REVIEW_SAMPLING_RATE=0.02
# 采样模式，当前可用值为 rule、llm、rule_llm。
SEARCH_REVIEW_SAMPLING_MODE="rule_llm"
# 搜索评审坏例子阈值，低于该值会写入 bad case 输出。
SEARCH_REVIEW_BAD_CASE_THRESHOLD=0.55

# =============== LLM / Embedding ===============
# 系统默认聊天模型 API Key，可留空表示依赖用户自带 key 或本地 Ollama。
LLM_DEFAULT_API_KEY=""
# 系统默认 embedding API Key。
EMBEDDING_DEFAULT_API_KEY=""
# 默认聊天 provider。
DEFAULT_CHAT_PROVIDER="ollama"
# 默认聊天模型名。
DEFAULT_CHAT_MODEL_NAME="qwen3.5:0.8b"
# 默认聊天 provider 地址。
DEFAULT_CHAT_API_URL="http://127.0.0.1:11434"
# 默认搜索 provider，当前固定为 exa。
DEFAULT_SEARCH_PROVIDER="exa"
# 默认 embedding provider。
DEFAULT_EMBEDDING_PROVIDER="ollama"
# 默认 embedding 模型名。
DEFAULT_EMBEDDING_MODEL_NAME="qwen3-embedding:0.6b"
# 默认 embedding provider 地址。
DEFAULT_EMBEDDING_API_URL="http://127.0.0.1:11434"
# embedding 维度，当前系统统一为 1024。
EMBEDDING_OUTPUT_DIMENSIONS=1024
# chunk 目标 token 数。
CHUNK_TARGET_TOKENS=600
# chunk overlap token 数。
CHUNK_OVERLAP_TOKENS=80
# summary 缓存天数。
SUMMARY_CACHE_TTL_DAYS=30
# 是否启用 AI 在线评审。
AI_REVIEW_SAMPLING_ENABLED=true
# AI 在线评审采样比例，建议在 0.01 到 0.05 之间。
AI_REVIEW_SAMPLING_RATE=0.02
# AI 在线评审模式，当前固定为 llm。
AI_REVIEW_SAMPLING_MODE="llm"
# AI 在线评审坏例子阈值，低于该值会写入 bad case 输出。
AI_REVIEW_BAD_CASE_THRESHOLD=0.6
# scheduler 清理失败 job 的保留天数。
SCHEDULER_FAILED_JOB_RETENTION_DAYS=14

# =============== Kafka ===============
# Kafka bootstrap servers。
KAFKA_BOOTSTRAP_SERVERS="127.0.0.1:29092"
# 应用异步任务 topic。
KAFKA_TOPIC="notebook_async"
# consumer poll 超时，单位毫秒。
KAFKA_CONSUMER_POLL_TIMEOUT_MS=1000
# Kafka request timeout，单位毫秒。
KAFKA_REQUEST_TIMEOUT_MS=10000
# consumer 心跳超时，单位毫秒。handler 中的 sync 会阻塞 event loop，heartbeat 发不出，需设大些。默认 30 秒。
KAFKA_SESSION_TIMEOUT_MS=30000
# 两次 poll 之间允许的最大间隔，单位毫秒。超过则 consumer 被踢出 group 触发 rebalance。默认 10 分钟，适配长耗时 ingest。
KAFKA_MAX_POLL_INTERVAL_MS=600000
# offset reset 策略。
KAFKA_AUTO_OFFSET_RESET="earliest"

# =============== Object Storage ===============
# MinIO 或 S3 兼容对象存储地址。
OBJECT_STORAGE_ENDPOINT="127.0.0.1:9000"
# 对象存储 access key。
OBJECT_STORAGE_ACCESS_KEY="minioadmin"
# 对象存储 secret key。
OBJECT_STORAGE_SECRET_KEY="minioadmin"
# 默认 bucket 名称。
OBJECT_STORAGE_BUCKET="notebooklm"
# 是否启用 HTTPS。
OBJECT_STORAGE_SECURE=false
# 对象存储 region，可留空。
OBJECT_STORAGE_REGION=""
# 文件存储后端，当前支持 minio 或 local。
FILE_STORAGE_BACKEND="minio"

# =============== Telemetry / LangSmith ===============
# 应用日志级别。
LOG_LEVEL="INFO"
# 是否输出 JSON 日志。
LOG_JSON=true
# API metrics 暴露端口。
API_METRICS_PORT=8080
# worker metrics 暴露端口。
WORKER_METRICS_PORT=9101
# scheduler metrics 暴露端口。
SCHEDULER_METRICS_PORT=9102
# 是否启用 OpenTelemetry。
OTEL_ENABLED=true
# OTel service name。
OTEL_SERVICE_NAME="notebooklm-backend"
# OTLP traces 上报地址。
OTEL_EXPORTER_OTLP_ENDPOINT="http://127.0.0.1:4318/v1/traces"
# 是否启用 LangSmith。
LANGSMITH_ENABLED=false
# LangSmith API endpoint。
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
# LangSmith API key，本地可留空。
LANGSMITH_API_KEY=""
# LangSmith project 名称。
LANGSMITH_PROJECT="notebooklm-backend"
# LangSmith workspace id，可留空。
LANGSMITH_WORKSPACE_ID=""
# 是否启用 LangSmith tracing。
LANGSMITH_TRACING=false
# 允许的前端来源列表，使用 JSON 风格数组字符串。
CORS_ORIGINS='["http://127.0.0.1:5173","http://localhost:5173","http://127.0.0.1:5174","http://localhost:5174"]'

# =============== Frontend Vite ===============
# 前端数据源，可选 mock 或 api。
VITE_DATA_SOURCE="api"
# 前端直接请求 API 时的基础地址。
VITE_API_BASE_URL="http://127.0.0.1:8080/api"
# Vite 开发代理目标地址。
VITE_DEV_PROXY_TARGET="http://127.0.0.1:8080"
# 前端请求超时时间，单位毫秒。
VITE_API_TIMEOUT_MS=15000
